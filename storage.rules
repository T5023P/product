rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public reads for product images and signed-in admin UI uploads
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default: deny writes
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
